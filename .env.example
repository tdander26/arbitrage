# Copy to .env.local for local dev, and set the same vars in Vercel project
# settings (Settings → Environment Variables) for production.

# Earnings calendar (free tier). Used to auto-populate earnings dates.
# Get one at https://finnhub.io/  — leave unset to use seeded dates.
FINNHUB_API_KEY=

# Social volume via Apify (TikTok Trends Scraper etc.). Used to pull social
# activity per product. Get a token at https://console.apify.com/account/integrations
# Leave unset to log social numbers manually.
APIFY_TOKEN=

# Google Trends via SerpApi (reliable from serverless — the keyless endpoint
# is blocked from datacenter IPs). Results are cached a week to fit the free
# 100-search/month quota. Get a key at https://serpapi.com
SERPAPI_KEY=
