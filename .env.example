# Data source selection per signal layer. Default is `cache` (real seeded data
# with mock fallback). Set to `mock` to force the demo dataset everywhere.
MARKET_PROVIDER=cache
TRENDS_PROVIDER=cache
SOCIAL_PROVIDER=cache

# --- Optional live add-ons (Phase 3) ---
# Google Trends MCP (e.g. andrewlwn77/google-trends-mcp) — RapidAPI key:
# GOOGLE_TRENDS_API_KEY=
# Reddit (free) app credentials for a live social provider:
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
